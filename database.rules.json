{
  "rules": {
    // ⚠️ Rodinné dáta sú prístupné cez unikátny familyCode (8 znakov, A-Z, 2-9)
    // FamilyCode slúži ako de facto "password" pre zdieľanie v režime host/guest
    // Minimálna dĺžka 6 znakov — zabraňuje enumerácii krátkych kódov
    "families": {
      "$familyCode": {
        ".read": true,
        ".write": "$familyCode.length >= 6",
        // Validácia pre member záznamy
        "members": {
          "$memberId": {
            ".validate": "newData.hasChildren(['name', 'lastSeen']) && newData.child('name').isString() && newData.child('name').val().length < 50"
          }
        }
      }
    },
    // 🔐 Push notifikačné tokeny sú chránené — vyžadujú Firebase Auth
    // Toto zabraňuje zneužitiu tokenov na spamovanie notifikácií
    "pushTokens": {
      ".read": "auth !== null",
      ".write": "auth !== null"
    }
  }
}
